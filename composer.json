{
    "name": "blackbird/magento2-index-monitoring",
    "description": "Magento 2 module for monitoring indexers and mview states with email alerts",
    "type": "magento2-module",
    "version": "1.0.0",
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "magento/framework": "^103.0",
        "magento/module-indexer": "^100.4",
        "magento/module-variable": "^100.4",
        "magento/module-email": "^101.1",
        "magento/module-backend": "^102.0"
    },
    "autoload": {
        "files": [
